{
  "name": "brain-sidecar-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:hosted": "playwright test --config=playwright.hosted.config.ts",
    "test:e2e:hosted:caddy": "bash ../scripts/test_hosted_caddy.sh",
    "test:e2e:integration": "bash ../scripts/test_e2e_integration.sh",
    "test:user-audio": "bash ../scripts/test_user_audio.sh",
    "playwright:install": "playwright install --with-deps chromium",
    "e2e": "npm run test:e2e",
    "e2e:ui": "npm run test:e2e:ui"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "vite": "^7.2.0",
    "typescript": "^5.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
